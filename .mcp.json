{
  "mcpServers": {
    "aida-lore": {
      "command": "node",
      "args": [
        "mcp-server/dist/index.js"
      ],
      "env": {
        "LORE_BACKEND_URL": "https://lore.odal.seidrstudio.pro",
        "LORE_SEER_ROLE": "admin",
        "LORE_OIDC_ISSUER": "https://odal.seidrstudio.pro/kc/realms/omilore",
        "LORE_MCP_CLIENT_ID": "lore-mcp-full",
        "LORE_MCP_CLIENT_SECRET": "${LORE_MCP_CLIENT_SECRET}"
      }
    },
    "forgejo-mcp": {
      "type": "http",
      "url": "http://192.168.3.131:3400/mcp",
      "headers": {
        "Authorization": "Bearer ${FORGEJO_MCP_API_KEY}"
      }
    }
  }
}
