# Normalize line endings; keep shell/wrapper as LF so Linux containers can run them.
* text=auto eol=lf
*.bat        text eol=crlf
*.cmd        text eol=crlf
backend/gradlew text eol=lf
# Binary assets — never normalize.
*.jar  binary
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
