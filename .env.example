# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ── Frontend (Vite dev) ───────────────────────────────────────────────────────
# Base URL of the lore-backend REST API. Dev proxy target; leave as-is locally.
VITE_LORE_API_URL=http://localhost:9100
VITE_BENCH_API_URL=http://localhost:9100

# ── A2 auth (off by default — see docs/AUTH_OMILORE.md) ───────────────────────
# Leave VITE_LORE_AUTH_ENABLED unset/false until the omilore realm is imported
# AND the backend's LORE_AUTH_ENABLED is also flipped on — flip both together,
# never one without the other. When on, must match VITE_OIDC_ISSUER's realm.
# VITE_LORE_AUTH_ENABLED=true
# VITE_OIDC_ISSUER=http://localhost:18180/kc/realms/omilore
# VITE_OIDC_CLIENT_ID=lore-app

# ── Keycloak: realm provisioning + KC bridge (ADR-LORE-025, SPEC-RBAC) ────────
# Провижининг realm `omilore` (скрипт backend/keycloak/kc-provision-agents.js —
# идемпотентный: 7 клиентов lore-mcp-<профиль> с client-ролью agent-* и маппером
# agent_scope + клиент lore-admin для KC-моста). Нужен админ мастер-realm'а KC.
# Скрипт читает эти значения из .env — задаётся ОДИН раз, дальше не спрашивается.
# KC_ADMIN_USER=admin
# KC_ADMIN_PASS=change-me

# Секрет клиента lore-admin (KC → Clients → lore-admin → Credentials). Читается
# бэкендом через SecretProvider (D15) и подставляется в lore-backend compose'ом.
# НЕ задан → /lore/kc/* отвечает 503 «not configured», остальной LORE работает
# как обычно (pluggable, D14). Появится ПОСЛЕ первого запуска провижининга.
# KC_ADMIN_CLIENT_SECRET=
# KC_ADMIN_URL=http://localhost:18180/kc
# KC_ADMIN_REALM=omilore

# ── Провайдер секретов (D15): env (дефолт, ничего не требует) | infisical ─────
# При infisical секреты (KC_ADMIN_CLIENT_SECRET, FORGEJO_API_TOKEN) читаются из
# секрет-сервиса, а в .env остаётся только бутстрап — учётка самого сервиса.
# Недоступен сервис → мосты отвечают 503 «not configured», остальной LORE живёт.
# LORE_SECRETS_PROVIDER=infisical
# LORE_SECRETS_URL=http://infisical:18080
#
# Machine identity (Universal Auth): организация → Access Control → Identities →
# Create Identity (org-роль no-access) → на её странице Add Auth Method →
# Universal Auth → Client ID + Add Client Secret. Затем ОБЯЗАТЕЛЬНО добавить эту
# identity в сам проект (Projects → + → роль Viewer): без этого логин проходит,
# а секреты не читаются.
# LORE_SECRETS_CLIENT_ID=
# LORE_SECRETS_CLIENT_SECRET=
#
# Project ID — проект → Settings → General (он же в URL). Для machine identity
# обязателен вместе с окружением: access-token сам по себе не указывает, откуда
# читать, и без них сервис отвечает 400 — а выглядит как «секрета нет».
# LORE_SECRETS_PROJECT_ID=
# LORE_SECRETS_ENVIRONMENT=prod
# LORE_SECRETS_SCOPE=/lore
#
# Сервисный токен — ЛЕГАСИ: в свежих сборках Infisical их больше не выпускают
# (в Project Settings нет ни вкладки, ни секции). Оставлен для старых инстансов.
# LORE_SECRETS_TOKEN=

# ── ArcadeDB (:2480, shared with the monorepo) ────────────────────────────────
# Read by docker compose for ${ARCADEDB_ROOT_PASSWORD} substitution and by the
# backend for Basic auth against :2480. Must match the Ygg ArcadeDB container
# (arcadedb.server.rootPassword). Without it, compose falls back to "unset" and
# the backend gets 403 from :2480.
ARCADEDB_USER=root
ARCADEDB_ROOT_PASSWORD=change-me

# ── MinIO (BRAGI asset uploads) ───────────────────────────────────────────────
# Defaults live in docker-compose.yml; override here for non-default creds.
MINIO_USER=aida
MINIO_PASSWORD=change-me
S3_BUCKET=bragi-assets
