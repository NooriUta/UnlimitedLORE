# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ── Frontend (Vite dev) ───────────────────────────────────────────────────────
# Base URL of the lore-backend REST API. Dev proxy target; leave as-is locally.
VITE_LORE_API_URL=http://localhost:9100
VITE_BENCH_API_URL=http://localhost:9100

# ── ArcadeDB (:2480, shared with the monorepo) ────────────────────────────────
# Read by docker compose for ${ARCADEDB_ROOT_PASSWORD} substitution and by the
# backend for Basic auth against :2480. Must match the Ygg ArcadeDB container
# (arcadedb.server.rootPassword). Without it, compose falls back to "unset" and
# the backend gets 403 from :2480.
ARCADEDB_USER=root
ARCADEDB_ROOT_PASSWORD=change-me

# ── MinIO (BRAGI asset uploads) ───────────────────────────────────────────────
# Defaults live in docker-compose.yml; override here for non-default creds.
MINIO_USER=aida
MINIO_PASSWORD=change-me
S3_BUCKET=bragi-assets
