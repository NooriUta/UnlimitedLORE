{
  "realm": "omilore",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "admin",       "description": "LORE admin — full write access to system_aida_lore via the backend." },
      { "name": "super-admin", "description": "LORE super-admin — admin + destructive/admin-only endpoints." },
      { "name": "viewer",      "description": "LORE read-only." }
    ]
  },
  "clients": [
    {
      "clientId": "lore-app",
      "name": "LORE frontend (SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4400/*",
        "http://localhost:5190/*"
      ],
      "webOrigins": [
        "http://localhost:4400",
        "http://localhost:5190"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4400/*##http://localhost:5190/*"
      },
      "protocolMappers": [
        {
          "name": "lore-realm-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "seer_roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "lore-mcp",
      "name": "LORE MCP server (service account)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "CHANGE-ME-lore-mcp-secret",
      "protocolMappers": [
        {
          "name": "lore-realm-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "seer_roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "_notes": "Import into the shared KC (aida-root-keycloak-1, http://localhost:18180/kc). Assign the 'admin' realm role to the lore-mcp service-account user so MCP writes pass requireAdmin. Rotate the lore-mcp secret before any non-local use. Realm roles land in the 'seer_roles' access-token claim (matches quarkus.oidc.roles.role-claim-path)."
}
