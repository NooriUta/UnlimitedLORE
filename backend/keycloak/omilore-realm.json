{
  "realm": "omilore",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "loginTheme": "lore",
  "internationalizationEnabled": true,
  "supportedLocales": ["ru", "en"],
  "defaultLocale": "ru",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "admin",       "description": "LORE admin — full write access to system_aida_lore via the backend." },
      { "name": "super-admin", "description": "LORE super-admin — admin + destructive/admin-only endpoints." },
      { "name": "viewer",      "description": "LORE read-only." }
    ]
  },
  "_comment_lore_audience": "AL-72. Аудитория вынесена в ОДИН client scope, а не продублирована мапперами по клиентам, и это не вкусовщина: в живом realm клиентов не два, а десять (lore-app, lore-admin, lore-mcp-full и семь агентских профилей lore-mcp-*). Дублировать маппер десять раз означало бы, что когда-нибудь его забудут добавить одиннадцатому — и этот клиент молча получит токен без нужной аудитории. Scope помечен Default, поэтому НОВЫЕ клиенты подхватывают его сами. Существующим он проставлен вручную 2026-07-21.",
  "clientScopes": [
    {
      "name": "lore-audience",
      "description": "AL-72: audience lore-api for the LORE backend. Without it KC issues the default aud=account.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "lore-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "lore-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "lore-app",
      "name": "LORE frontend (SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4400/*",
        "http://localhost:5190/*",
        "http://lore.odal.seidrstudio.pro:4400/*",
        "http://192.168.3.131:4400/*",
        "https://lore.odal.seidrstudio.pro/*"
      ],
      "webOrigins": [
        "http://localhost:4400",
        "http://localhost:5190",
        "http://lore.odal.seidrstudio.pro:4400",
        "http://192.168.3.131:4400",
        "https://lore.odal.seidrstudio.pro"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "lore-realm-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "seer_roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": ["lore-audience"]
    },
    {
      "clientId": "lore-mcp",
      "name": "LORE MCP server (ОТКЛЮЧЁН — нет маппера agent_scope, см. AUTH_OMILORE шаг 4)",
      "enabled": false,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "CHANGE-ME-lore-mcp-secret",
      "protocolMappers": [
        {
          "name": "lore-realm-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "seer_roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": ["lore-audience"]
    }
  ]
}
